# verify.yaml — minimal valid example for `maestro verify write`.
#
# This file is the on-disk format for the verification commands the daemon
# runs after a Worker reports a task as completed. Provide AT LEAST one
# command across the verify.* categories below; an empty file is rejected
# by validateRequiredVerifySnapshot in internal/plan/submit.go.
#
# Usage:
#   maestro verify write --command-id <command_id> --config-file verify.yaml
# or via stdin:
#   cat verify.yaml | maestro verify write --command-id <command_id> --config-file -
#
# Constraints (enforced by VerifyConfig.Validate):
#   - Each command is direct-exec; shell metacharacters (`;`, `&&`, `||`,
#     backtick, `$(`, `${`, pipe, redirect, newline) are NOT allowed.
#     If a command needs them, wrap it in a script that the verify command
#     invokes by path.
#   - `sh -c` / `bash -c` invocations are rejected.
#   - Leading `KEY=VALUE` env assignments are allowed (e.g. `CGO_ENABLED=0
#     go test ./...`).
#
# Replace the example commands below with the verification suite for the
# project you are gating. The categories are advisory groupings only; all
# commands run regardless of which category they appear under.

verify:
  build:
    - go vet ./...
  lint:
    - go vet ./...
  test:
    - go test ./...
  typecheck: []
  # security and performance categories are optional (C-3 extension).
  # security:
  #   - govulncheck ./...
  # performance:
  #   - go test -bench=. -benchtime=1x ./...
